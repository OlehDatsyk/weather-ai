# ---------------------------------------------------------------------------
# Skyline — AI Weather Assistant
# Copy this file to ".env" and fill in your own values. Never commit ".env".
# ---------------------------------------------------------------------------

# --- Flask ---------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-64-char-hex-string
FLASK_DEBUG=true
HOST=127.0.0.1
PORT=5000

# --- Weather provider (OpenWeatherMap) ------------------------------------
# Free key: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5
# metric = Celsius, imperial = Fahrenheit
WEATHER_UNITS=metric

# --- AI provider -----------------------------------------------------------
# Choose ONE provider: "openai" or "anthropic"
AI_PROVIDER=openai

# OpenAI (Responses API) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1

# Anthropic (Messages API) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# AI generation tuning
AI_MAX_TOKENS=900
AI_TEMPERATURE=0.7

# --- App limits --------------------------------------------------------------
MAX_CITIES_COMPARE=4
MAX_HISTORY_MESSAGES=12
